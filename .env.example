# URL publique de l’app (sans slash final). Utilisée pour les liens /play et les QR codes.
# En local, Spotify n’accepte plus « localhost » en redirect URI : utilise 127.0.0.1 et ouvre l’app sur http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service (serveur uniquement) — requise pour l’admin et les routes API sécurisées
SUPABASE_SERVICE_ROLE_KEY=

# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Identique au redirect enregistré dans le dashboard Spotify (obligatoire : IP loopback, pas « localhost »)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
# Espace-séparé. Premium + compte développeur pour le Web Playback SDK.
# Inclure playlist-read-private pour importer des playlists privées depuis l’admin.
SPOTIFY_SCOPES="streaming user-read-playback-state user-modify-playback-state user-read-email user-read-private playlist-read-private"

# Admin V1 : mot de passe + secret pour signer le cookie de session
ADMIN_PASSWORD=
# Chaîne aléatoire longue (ex. openssl rand -hex 32)
ADMIN_SESSION_SECRET=
